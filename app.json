{
  "expo": {
    "name": "mati-ecom",
    "slug": "mati-ecom",
    "version": "1.0.0",
    "scheme": "matiecom",
    "icon": "./assets/images/farming_lion.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.farminglegion.app",
      "supportsTablet": true
    },
    "android": {
      "package": "farminglegion.com",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/farming_lion.png"
      },
      "permissions": ["CAMERA"]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mati Ecom to access your camera to scan QR codes."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "46ca8665-47a4-4f08-bca4-51d6dc4bef83"
      }
    }
  }
}
