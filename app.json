{
  "expo": {
    "name": "mati-ecom",
    "slug": "mati-ecom",
    "version": "1.0.0",
    "scheme": "matiecom",
    "icon": "./assets/images/farming_lion.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "demo.app",
      "supportsTablet": true
    },
    "android": {
      "package": "demo.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/farming_lion.png"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "46ca8665-47a4-4f08-bca4-51d6dc4bef83"
      }
    }
  }
}
